{
    "name": "deep-packet-analyzer",
    "private": true,
    "version": "0.0.0",
    "packageManager": "pnpm@8.6.0",
    "workspaces": [
        "apps/*",
        "packages/*",
        "engine/*",
        "web",
        "worker"
    ],
    "scripts": {
        "bootstrap": "pnpm -w install",
        "ci": "pnpm -w install && pnpm -w -r test",
        "lint": "eslint --cache --ext .js,.cjs,.mjs web worker",
        "lint:fix": "eslint --cache --fix --ext .js,.cjs,.mjs web worker",
        "test": "pnpm -w -r test",
        "build": "echo \"This monorepo contains C++ and JS packages; build per-package.\"",
        "dev": "pnpm -w --parallel --filter web start & pnpm -w --parallel --filter worker start",
        "format": "prettier --write \"**/*.{js,ts,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,ts,json,md}\"",
        "prepare": "husky",
        "db:migrate": "pnpm -w --filter @dpa/db migrate",
        "db:migrate:dev": "pnpm -w --filter @dpa/db migrate:dev",
        "db:reset": "pnpm -w --filter @dpa/db db:reset",
        "db:seed": "pnpm -w --filter @dpa/db db:seed",
        "db:studio": "pnpm -w --filter @dpa/db studio"
    },
    "devDependencies": {
        "eslint-config-prettier": "^9.1.0",
        "eslint": "^8.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.2.10",
        "prettier": "^3.0.0",
        "prettier-plugin-tailwindcss": "^0.6.8",
        "concurrently": "^8.0.0"
    },
    "lint-staged": {
        "*.{js,cjs,mjs}": [
            "prettier --write",
            "eslint --cache --fix"
        ],
        "*.{json,md,css,html}": [
            "prettier --write"
        ]
    }
}
